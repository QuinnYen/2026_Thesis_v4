# ==================================================
# 工具與環境
# ==================================================
/.claude
/.venv

# ==================================================
# 資料、實驗結果、文件（不追蹤）
# ==================================================
/data/
/results/
/backup/
/docs/
/tests/
/archived/

# ==================================================
# datasets/ 資料夾：Python 程式碼全部追蹤
# （/data/ 只存放原始資料集與知識庫，不追蹤）
# ==================================================

# ==================================================
# 模型權重與檢查點
# ==================================================
*.pt
*.pth
*.bin

# ==================================================
# Python cache
# ==================================================
__pycache__/
*.py[cod]
*$py.class
*.so

# ==================================================
# 雜項
# ==================================================
/nul
